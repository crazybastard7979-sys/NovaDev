# NovaDev Cloud IDE — Environment Variables
# Copy this file to .env and fill in values

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://novadev:your_password@localhost:5432/novadev
PGHOST=localhost
PGPORT=5432
PGUSER=novadev
PGPASSWORD=your_password
PGDATABASE=novadev

# ─── Authentication ───────────────────────────────────────────────────────────
SESSION_SECRET=your-super-secret-jwt-key-min-32-chars-change-me

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:your_redis_password@localhost:6379
REDIS_PASSWORD=your_redis_password

# ─── AI Providers (optional — app works without them) ─────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...

# ─── Deployment ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080

# ─── Frontend (set at build time on Railway) ──────────────────────────────────
# Full URL of the API server — required when frontend and API are on separate domains
VITE_API_URL=https://your-api-service.railway.app
BASE_PATH=/

# ─── Docker / Infra ───────────────────────────────────────────────────────────
POSTGRES_PASSWORD=novadev_secret_change_me
